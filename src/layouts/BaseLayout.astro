---
import { ClientRouter } from 'astro:transitions'
import '../styles/global.css'

interface Props {
  lang: 'es' | 'en'
  title: string
  description: string
}

const { lang, title, description } = Astro.props

const canonical = new URL(Astro.url.pathname, Astro.site)
const ogImage = new URL('/og.png', Astro.site)
const esUrl = new URL('/', Astro.site)
const enUrl = new URL('/en/', Astro.site)
const ogLocale = lang === 'es' ? 'es_ES' : 'en_US'
const ogLocaleAlt = lang === 'es' ? 'en_US' : 'es_ES'

const person = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Alex Avila Asto',
  alternateName: 'Ryzeon',
  url: Astro.site?.href,
  image: ogImage.href,
  jobTitle: 'Software Engineer',
  email: 'mailto:aavilaasto@gmail.com',
  description,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Lima',
    addressCountry: 'PE',
  },
  alumniOf: {
    '@type': 'CollegeOrUniversity',
    name: 'Universidad Peruana de Ciencias Aplicadas (UPC)',
  },
  knowsAbout: [
    'Backend Development',
    'Cloud Computing',
    'DevOps',
    'Java',
    'Spring Boot',
    'AWS',
    'Azure',
    'Kubernetes',
  ],
  sameAs: ['https://github.com/Ryzeon', 'https://linkedin.com/in/alex-avila-asto'],
}
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Alex Avila Asto" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#f7f1e3" />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={esUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Alex Avila Asto" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Space+Grotesk:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(person)} />

    <ClientRouter />
  </head>
  <body id="top">
    <slot />
  </body>
</html>
