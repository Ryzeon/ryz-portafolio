---
interface Props {
  number: string
  title: string
}

const { number, title } = Astro.props
---

<div class="heading">
  <span class="heading__number">{number}</span>
  <h2 class="heading__title">{title}</h2>
</div>

<style>
  .heading {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 28px;
  }

  .heading__number {
    font-family: var(--pf-font-display);
    font-size: 26px;
    color: var(--pf-primary);
    -webkit-text-stroke: 1.5px var(--pf-ink);
  }

  .heading__title {
    font-family: var(--pf-font-display);
    font-size: clamp(24px, 4vw, 40px);
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }
</style>
