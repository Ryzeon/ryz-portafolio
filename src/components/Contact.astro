---
import type { UIStrings } from '../i18n/types'
import type { Social } from '../data/portfolio'

interface Props {
  ui: UIStrings
  socials: Social[]
}

const { ui, socials } = Astro.props

const email = socials.find((social) => social.key === 'Email')
const mailto = email?.href ?? 'mailto:contact@ryzeon.dev'
---

<section id="contact" class="contact">
  <div class="pf-container contact__inner">
    <span class="contact__label">05 — {ui.contactLabel}</span>
    <h2 class="contact__title">{ui.contactTitle}</h2>
    <p class="contact__body">{ui.contactBody}</p>

    <form
      class="contact__form"
      id="contact-form"
      data-sending={ui.form.sending}
      data-success={ui.form.success}
      data-error={ui.form.error}
    >
      <div class="contact__row">
        <div class="contact__field">
          <label for="cf-name">{ui.form.nameLabel}</label>
          <input
            id="cf-name"
            name="name"
            type="text"
            required
            maxlength="120"
            placeholder={ui.form.namePlaceholder}
          />
        </div>
        <div class="contact__field">
          <label for="cf-email">{ui.form.emailLabel}</label>
          <input
            id="cf-email"
            name="email"
            type="email"
            required
            placeholder={ui.form.emailPlaceholder}
          />
        </div>
      </div>

      <div class="contact__field">
        <label for="cf-message">{ui.form.messageLabel}</label>
        <textarea
          id="cf-message"
          name="message"
          required
          rows="5"
          maxlength="5000"
          placeholder={ui.form.messagePlaceholder}></textarea>
      </div>

      <input
        type="text"
        name="company"
        class="contact__hp"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
      />

      <button type="submit" class="contact__submit pf-press-light">{ui.form.send} →</button>
      <p class="contact__status" role="status" aria-live="polite"></p>
    </form>

    <a href={mailto} class="contact__fallback">{ui.contactCta} →</a>

    <div class="contact__socials">
      {
        socials.map((social) =>
          social.copy ? (
            <button
              type="button"
              class="contact__social pf-press"
              data-copy={social.copy}
              data-copied={ui.copied}
            >
              <span class="contact__social-key">{social.key}</span>
              <span class="contact__social-value">{social.value}</span>
            </button>
          ) : (
            <a href={social.href} target="_blank" rel="noopener" class="contact__social pf-press">
              <span class="contact__social-key">{social.key}</span>
              <span class="contact__social-value">{social.value}</span>
            </a>
          ),
        )
      }
    </div>

    <div class="contact__footer">
      <span>© 2026 Alex Avila Asto — Lima, Peru · Open to remote</span>
      <span class="contact__hint">{ui.saveHint}</span>
    </div>
  </div>
</section>

<style>
  .contact {
    border-top: 3px solid var(--pf-ink);
    background: var(--pf-primary);
  }

  .contact__inner {
    padding-block: 72px;
  }

  .contact__label {
    display: inline-block;
    font-family: var(--pf-font-mono);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    background: var(--pf-ink);
    color: var(--pf-bg);
    padding: 6px 12px;
    margin-bottom: 20px;
  }

  .contact__title {
    font-family: var(--pf-font-display);
    font-size: clamp(40px, 8vw, 100px);
    line-height: 0.9;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    margin-bottom: 26px;
  }

  .contact__body {
    font-size: 17px;
    font-weight: 500;
    line-height: 1.55;
    max-width: 540px;
    margin-bottom: 34px;
  }

  .contact__form {
    max-width: 620px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .contact__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .contact__field label {
    font-family: var(--pf-font-mono);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
  }

  .contact__field input,
  .contact__field textarea {
    font-family: var(--pf-font-body);
    font-size: 15px;
    color: var(--pf-ink);
    background: var(--pf-bg);
    border: 2px solid var(--pf-ink);
    padding: 12px 14px;
    resize: vertical;
  }

  .contact__field input:focus-visible,
  .contact__field textarea:focus-visible {
    outline: 3px solid var(--pf-ink);
    outline-offset: 2px;
  }

  .contact__hp {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    border: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }

  .contact__submit {
    align-self: flex-start;
    font-family: var(--pf-font-mono);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    padding: 16px 30px;
    background: var(--pf-ink);
    color: var(--pf-bg);
    border: 2px solid var(--pf-ink);
    box-shadow: 5px 5px 0 var(--pf-bg);
    cursor: pointer;
    transition: transform 0.12s, box-shadow 0.12s;
  }

  .contact__submit:hover,
  .contact__submit:focus-visible {
    transform: translate(2px, 2px);
    box-shadow: 1px 1px 0 var(--pf-bg);
  }

  .contact__submit:disabled {
    cursor: progress;
    opacity: 0.7;
  }

  .contact__status {
    font-family: var(--pf-font-mono);
    font-size: 13px;
    font-weight: 700;
    min-height: 1.2em;
  }

  .contact__status.is-success {
    color: var(--pf-ink);
  }

  .contact__status.is-error {
    color: #b11400;
  }

  .contact__fallback {
    display: inline-block;
    font-family: var(--pf-font-mono);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    margin-top: 24px;
    border-bottom: 2px solid var(--pf-ink);
  }

  .contact__socials {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
    margin-top: 48px;
  }

  .contact__social {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: var(--pf-bg);
    border: 2px solid var(--pf-ink);
    padding: 16px;
    box-shadow: 4px 4px 0 var(--pf-ink);
  }

  button.contact__social {
    font: inherit;
    text-align: left;
    width: 100%;
    cursor: pointer;
  }

  .contact__social-key {
    font-family: var(--pf-font-mono);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .contact__social-value {
    font-weight: 700;
    font-size: 14px;
  }

  .contact__footer {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 18px;
    justify-content: space-between;
    font-family: var(--pf-font-mono);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    margin-top: 40px;
    border-top: 2px solid var(--pf-ink);
    padding-top: 18px;
  }

  .contact__hint {
    opacity: 0.7;
  }

  @media (min-width: 560px) {
    .contact__row {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 620px) {
    .contact__socials {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>

<script>
  document.querySelectorAll('[data-copy]').forEach((element) => {
    element.addEventListener('click', async () => {
      const text = element.getAttribute('data-copy')
      if (!text) return

      try {
        await navigator.clipboard.writeText(text)
      } catch {
        return
      }

      const value = element.querySelector('.contact__social-value')
      if (!value) return

      const original = value.textContent
      value.textContent = element.getAttribute('data-copied') ?? original
      setTimeout(() => {
        value.textContent = original
      }, 1200)
    })
  })

  const form = document.getElementById('contact-form') as HTMLFormElement | null

  if (form) {
    const button = form.querySelector('button[type="submit"]') as HTMLButtonElement
    const status = form.querySelector('.contact__status') as HTMLParagraphElement
    const sendLabel = button.textContent ?? ''

    form.addEventListener('submit', async (event) => {
      event.preventDefault()

      const payload = Object.fromEntries(new FormData(form).entries())
      button.disabled = true
      button.textContent = form.dataset.sending ?? ''
      status.textContent = ''
      status.classList.remove('is-success', 'is-error')

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        })

        if (!response.ok) throw new Error('request_failed')

        form.reset()
        status.textContent = form.dataset.success ?? ''
        status.classList.add('is-success')
      } catch {
        status.textContent = form.dataset.error ?? ''
        status.classList.add('is-error')
      } finally {
        button.disabled = false
        button.textContent = sendLabel
      }
    })
  }
</script>
