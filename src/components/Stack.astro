---
import SectionHeading from './SectionHeading.astro'
import type { UIStrings } from '../i18n/types'
import type { StackGroup } from '../data/portfolio'

interface Props {
  ui: UIStrings
  groups: StackGroup[]
}

const { ui, groups } = Astro.props
---

<section id="stack" class="pf-container pf-section">
  <SectionHeading number="02" title={ui.stackTitle} />

  <div class="stack__grid">
    {
      groups.map((group) => (
        <div class="stack__card">
          <span class="stack__label" style={`background:${group.color}`}>
            {group.label}
          </span>
          <div class="stack__items">
            {group.items.map((item) => <span class="stack__item">{item}</span>)}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .stack__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .stack__card {
    border: 3px solid var(--pf-ink);
    background: var(--pf-paper);
    padding: 20px;
    box-shadow: 5px 5px 0 var(--pf-ink);
  }

  .stack__label {
    display: inline-block;
    font-family: var(--pf-font-mono);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    padding: 4px 10px;
    border: 2px solid var(--pf-ink);
    margin-bottom: 14px;
  }

  .stack__items {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
  }

  .stack__item {
    font-size: 13px;
    font-weight: 600;
    padding: 4px 10px;
    border: 2px solid var(--pf-ink);
  }

  @media (min-width: 480px) {
    .stack__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 720px) {
    .stack__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
