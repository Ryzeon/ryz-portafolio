---
import type { Lang } from '../i18n/types'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const cvUrl = lang === 'es' ? 'https://cv.ryzeon.me/es/' : 'https://cv.ryzeon.me'
---

<script define:vars={{ cvUrl }}>
  // Re-runs on each view transition; replace the handler so it never stacks
  // and always points at the current language's CV.
  if (window.__cvShortcut) {
    window.removeEventListener('keydown', window.__cvShortcut)
  }
  window.__cvShortcut = (event) => {
    if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 's') {
      event.preventDefault()
      window.open(cvUrl, '_blank', 'noopener')
    }
  }
  window.addEventListener('keydown', window.__cvShortcut)
</script>
